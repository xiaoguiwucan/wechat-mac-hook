# 复制为 config/ai_reply.env 后填写。不要提交/外传这个文件。
# OpenAI-compatible：OpenAI / DeepSeek / 硅基流动 / OpenRouter / 本地兼容服务都可。

# OpenAI 示例：
# export OPENAI_API_KEY="sk-..."
# export AI_REPLY_BASE_URL="https://api.openai.com/v1"
# export AI_REPLY_MODEL="gpt-4o-mini"

# DeepSeek 示例：
# export OPENAI_API_KEY="sk-..."
# export AI_REPLY_BASE_URL="https://api.deepseek.com/v1"
# export AI_REPLY_MODEL="deepseek-chat"

# 本地 OpenAI-compatible 服务示例：
# export OPENAI_API_KEY="local-no-key"
# export AI_REPLY_BASE_URL="http://127.0.0.1:1234/v1"
# export AI_REPLY_MODEL="local-model"

# 调试：只记录不发送
# export AI_REPLY_DRY_RUN="1"

# 可选：忽略当前微信自己发出的消息，避免未来 OneBot 把自发群消息也回调回来时形成循环
# export AI_REPLY_IGNORE_SELF="1"

# Optional image OCR / vision key
export AI_REPLY_VISION_OCR_API_KEY=

# Optional ASR voice transcription key
export AI_REPLY_ASR_API_KEY=

# Hermes API：只作为工具与自动化执行层，不启用 Hermes 自带微信通道。
export HERMES_ENABLED=0
export HERMES_API_URL=http://127.0.0.1:8642
export HERMES_API_KEY=
export HERMES_WORKSPACE=
export HERMES_MAX_RUN_SECONDS=3600

# 四个隔离工作池，共 32 个线程。
export HERMES_READ_WORKERS=16
export HERMES_CRON_WORKERS=6
export HERMES_OPS_WORKERS=8
export HERMES_HIGH_WORKERS=2
export HERMES_QUEUE_SIZE=1000

# 普通工具查询 0～30 秒保持静默，超过 30 秒才发送一次查询中提示。
export HERMES_ANSWER_ACK_DELAY_SECONDS=30

# 持久结果缓存：默认 24 小时、天气 1 小时、行情 15 分钟、新闻 6 小时、状态 2 分钟。
export HERMES_CACHE_DEFAULT_SECONDS=86400
export HERMES_CACHE_WEATHER_SECONDS=3600
export HERMES_CACHE_MARKET_SECONDS=900
export HERMES_CACHE_NEWS_SECONDS=21600
export HERMES_CACHE_STATUS_SECONDS=120
