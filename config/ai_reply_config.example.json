{
  "enabled": false,
  "dry_run": true,
  "listen_host": "127.0.0.1",
  "listen_port": 36060,
  "onebot_api": "http://127.0.0.1:58080",
  "target_groups": [
    {
      "id": "1234567890@chatroom",
      "name": "值班群"
    }
  ],
  "allowed_user_ids": [],
  "ignored_user_ids": [],
  "ignored_group_members": {},
  "ignore_prefixes": [
    "AI：",
    "AI:",
    "🤖"
  ],
  "ignore_self_messages": true,
  "log_all_group_messages": true,
  "require_keyword": false,
  "trigger_keywords": [],
  "reply_prefix": "AI：",
  "max_context_messages": 8,
  "max_reply_chars": 600,
  "min_seconds_between_replies_per_group": 2.0,
  "send_delay_seconds": 0.2,
  "personality": "专业、克制、直接。回答简洁，不说空话。",
  "group_aliases": {
    "1234567890@chatroom": "值班群"
  },
  "memory": {
    "enabled": true,
    "max_turns": 12,
    "summary_enabled": true
  },
  "tools": {
    "enabled": true,
    "allowed": [
      "get_status",
      "get_recent_logs",
      "list_groups",
      "test_model_channel",
      "send_probe",
      "search_messages",
      "get_group_memory",
      "vector_search",
      "list_personas",
      "list_media",
      "send_voice_pack",
      "send_face_pack"
    ]
  },
  "ai": {
    "provider": "openai_compatible",
    "base_url": "https://api.deepseek.com/v1",
    "api_key_env": "AI_REPLY_CHANNEL_PRIMARY_API_KEY",
    "model": "deepseek-chat",
    "temperature": 0.3,
    "max_tokens": 600,
    "timeout_seconds": 30,
    "system_prompt": "你是微信群值班助手。只根据群聊最新消息和少量上下文，用中文简洁回复；不确定时先澄清；不要编造事实；不要输出多余客套；回复适合直接发到群里。",
    "channels": [
      {
        "id": "primary",
        "name": "DeepSeek",
        "provider": "openai_compatible",
        "base_url": "https://api.deepseek.com/v1",
        "api_key_env": "AI_REPLY_CHANNEL_PRIMARY_API_KEY",
        "model": "deepseek-chat",
        "timeout_seconds": 30,
        "enabled": true,
        "priority": 0
      }
    ],
    "active_channel_id": "primary",
    "auto_failover": true,
    "auto_health_check": true,
    "health_check_interval_seconds": 300,
    "failure_cooldown_seconds": 60
  },
  "reply_strategy": {
    "mode": "veteran",
    "threshold": 52,
    "scoring_mode": "local_fast",
    "rerank_candidates": 12,
    "bot_aliases": ["小风"],
    "followup_window_seconds": 120,
    "merge_window_ms": 2500,
    "global_workers": 8,
    "per_group_workers": 3,
    "model_concurrency": 6,
    "factor_weights": {
      "involvement": 18,
      "continuity": 14,
      "memory": 16,
      "value": 14,
      "humor": 14,
      "emotion": 10,
      "timing": 14
    },
    "modifiers": {
      "same_member_followup": 18,
      "exact_meme": 15,
      "high_vector": 12,
      "media_match": 8,
      "useful_after_silence": 6,
      "unfinished_fast_exchange": -25,
      "growing_burst": -15,
      "already_answered": -20,
      "low_information": -15
    }
  },
  "embedding": {
    "enabled": true,
    "base_url": "http://127.0.0.1:8017/v1",
    "model": "Qwen3-Embedding-8B-mxfp8",
    "reranker_model": "Qwen3-Reranker-4B-mxfp8",
    "dimensions": 4096,
    "batch_size": 32,
    "timeout_seconds": 120,
    "auto_backfill": true
  },
  "retrieval": {
    "vector_limit": 60,
    "fts_limit": 30,
    "person_limit": 12,
    "meme_limit": 12,
    "time_limit": 20,
    "media_limit": 16,
    "fusion_limit": 60,
    "adaptive_rerank": true,
    "rerank_cache_seconds": 600
  },
  "media_reply": {
    "automatic_enabled": true,
    "voice_probability": 0.15,
    "face_probability": 0.2,
    "voice_min_fit": 55,
    "face_min_fit": 45,
    "min_candidate_confidence": 0.65,
    "global_face_assets": true,
    "auto_media_replaces_text": true,
    "group_overrides": {}
  },
  "media_auto_repair": {
    "enabled": true,
    "filehelper_id": "filehelper",
    "cooldown_seconds": 45,
    "poll_seconds": 8
  },
  "onebot_monitor": {
    "enabled": true,
    "auto_recover": true
  },
  "wechat2_auto_login": {
    "enabled": true,
    "check_interval_seconds": 20,
    "cooldown_seconds": 60,
    "required_consecutive_detections": 2,
    "max_attempts_per_episode": 3
  },
  "poke_reply": {
    "enabled": false,
    "text_enabled": true,
    "image_enabled": false,
    "texts": ["拍我干嘛～", "在呢，别拍了。"],
    "face_ids": [],
    "bot_target_ids": [],
    "cooldown_seconds": 0
  },
  "vision_ocr": {
    "enabled": false,
    "auto_analyze": true,
    "base_url": "https://api.example.com/v1",
    "api_key_env": "AI_REPLY_VISION_OCR_API_KEY",
    "model": "your-vision-model",
    "timeout_seconds": 60,
    "prompt": "请提取图片中的可见文字，并用中文给出一句简短摘要。"
  },
  "asr": {
    "enabled": false,
    "base_url": "https://api.example.com/v1",
    "api_key_env": "AI_REPLY_ASR_API_KEY",
    "model": "your-asr-model",
    "timeout_seconds": 90,
    "language": "zh",
    "prompt": "",
    "auto_transcribe": true
  }
}
